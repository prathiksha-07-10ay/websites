<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PGC-GYM Landing Page</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700&display=swap" rel="stylesheet">

  <style>
    /* Base Setup */
    :root {
      --clr-primary: #29a396;
    }

    * {
      box-sizing: border-box;
      padding: 0;
      margin: 0;
      font-family: "Nunito", sans-serif;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      width: 100%;
      min-height: 100vh;
      background: radial-gradient(#111, #071a1a);
      color: #fff;
      overflow-x: hidden;
    }

    .container {
      width: 80%;
      margin: 0 auto;
    }

    .flex {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Header & Section Styles */
    .header,
    .section {
      width: 100%;
      padding: 40px 0;
      position: relative;
      overflow: hidden;
    }

    .header::after,
    .header::before,
    .section::after,
    .section::before {
      content: "";
      background: url(https://raw.githubusercontent.com/programmercloud/pgc-gym/main/img/blur-1.png);
      position: absolute;
      width: 400px;
      height: 400px;
      background-position: center;
      background-repeat: no-repeat;
      background-size: contain;
      bottom: 0;
      z-index: -1;
    }

    /* Menu & Navigation */
    .menu {
      width: 100%;
      background: linear-gradient(to right, #0e0e0e 70%, #142d2a);
      padding: 12px 0;
    }

    .menu .container {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      cursor: pointer;
    }

    .logo img {
      width: 80px;
      height: auto;
    }

    .nav {
      list-style: none;
    }

    .nav-item {
      display: inline-block;
      margin-right: 30px;
      font-size: 18px;
      font-weight: 400;
    }

    .nav-item a {
      text-decoration: none;
      color: #fff;
      transition: 0.3s linear;
    }

    .nav-item a:hover {
      color: var(--clr-primary);
    }

    .nav-item:last-of-type {
      margin-right: 0;
    }

    /* Buttons */
    .btn {
      padding: 10px 28px;
      background: var(--clr-primary);
      border-radius: 40px;
      font-size: 20px;
      font-weight: 400;
      text-decoration: none;
      color: #fff;
      display: inline-block;
      transition: 0.3s linear;
    }

    .btn:hover {
      background: #165f56;
    }

    .mobile-btn {
      display: none;
    }

    /* Main Typography styles */
    .primary {
      font-size: 70px;
      font-weight: 700;
    }

    .primary span {
      color: var(--clr-primary);
    }

    .secondary {
      font-size: 35px;
      font-weight: 700;
    }

    .tertiary {
      font-size: 15px;
    }

    .mb {
      margin-bottom: 30px;
    }

    .mt {
      margin-top: 20px;
    }

    /* Layout Columns */
    .text {
      width: 60%;
    }

    .visual {
      width: 40%;
    }

    .visual img {
      width: 100%;
    }

    /* Footer Styles */
    .footer {
      width: 100%;
      padding: 30px 0;
      border-top: 1px solid #ffffff1a;
      text-align: center;
    }

    /* Tutorial Link Floating Button Button Style */
    .youtube {
      position: fixed;
      bottom: 20px;
      right: 20px;
      background: #ff0000;
      color: #fff;
      text-decoration: none;
      padding: 10px 20px;
      border-radius: 30px;
      font-weight: bold;
      box-shadow: 0 4px 15px rgba(0,0,0,0.3);
      z-index: 999;
      transition: transform 0.2s;
    }
    
    .youtube:hover {
      transform: scale(1.05);
    }

    /* Responsive Media Queries */
    @media (max-width: 768px) {
      .flex {
        flex-direction: column;
        text-align: center;
      }

      .text, .visual {
        width: 100%;
      }

      .mobile-btn {
        display: block;
        font-size: 35px;
        cursor: pointer;
        position: absolute;
        right: 10%;
        top: 20px;
      }

      .nav {
        display: none;
        width: 100%;
        text-align: center;
        padding-top: 20px;
      }

      .menu.active .nav {
        display: block;
      }

      .nav-item {
        display: block;
        margin: 15px 0;
      }
    }
  </style>
</head>
<body>

  <header class="menu">
    <div class="container">
      <div class="logo">
        <img src="https://raw.githubusercontent.com/programmercloud/pgc-gym/main/img/logo.png" alt="PGC Gym Logo">
      </div>
      
      <div class="mobile-btn">
        <ion-icon name="menu-outline"></ion-icon>
      </div>

      <ul class="nav">
        <li class="nav-item"><a href="#">Home</a></li>
        <li class="nav-item"><a href="#why-us">Features</a></li>
        <li class="nav-item"><a href="#explore">Explore</a></li>
        <li class="nav-item"><a href="#discount">Register</a></li>
      </ul>
      
      <a href="#" class="btn header-btn">Register</a>
    </div>
  </header>

  <section class="header flex">
    <div class="container flex">
      <div class="text">
        <h1 class="primary mb">Complete Daily <br><span>Workout</span> At Home</h1>
        <p class="mb">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Minima sunt sed tempora neque molestiae corrupti nobis harum ullam eos nam!</p>
        <a href="#" class="btn">Get Started Now</a>
      </div>
      <div class="visual">
        <img src="https://raw.githubusercontent.com/programmercloud/pgc-gym/main/img/banner-img.png" alt="Workout Gym Banner">
      </div>
    </div>
  </section>

  <section id="discount" class="section flex">
    <div class="container flex">
      <div class="visual">
        <img src="https://raw.githubusercontent.com/programmercloud/pgc-gym/main/img/discount.png" alt="Gym Membership Discount Image">
      </div>
      <div class="text">
        <h2 class="primary mb">Fitness Classes This Summer, Pay Now And Get <span>25% Discount</span></h2>
        <p class="mb">Lorem ipsum dolor sit amet consectetur adipisicing elit. Ab maxime minus praesentium est et veniam voluptate laboriosam architecto. Dolorem quasi facere ducimus ullam?</p>
        <a href="#" class="btn bt">Book Now</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container flex">
      <p class="tertiary">
        &copy; 2022 Programmer Cloud. All Rights Reserved.
      </p>
    </div>
  </footer>
  
  <a href="https://www.youtube.com/watch?v=H_rRlMSbarg" class="youtube" target="_blank">
    <p>Watch Tutorial 🔥</p>
  </a>

  <script type="module" src="https://cdn.jsdelivr.net/npm/@ionic/core/dist/ionic/ionic.esm.js"></script>
  <script nomodule src="https://cdn.jsdelivr.net/npm/@ionic/core/dist/ionic/ionic.js"></script>

  <script>
    document.querySelector(".mobile-btn").addEventListener("click", function () {
      document.querySelector(".menu").classList.toggle("active");
    });
  </script>
</body>
</html>
